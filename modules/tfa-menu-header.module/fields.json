[
    {
        "name": "menu_settings",
        "label": "Menu Settings",
        "type": "group",
        "children": [
            {
                "name": "navigation_menu",
                "label": "Select Menu",
                "type": "menu"
            },
            {
                "name": "logo_height",
                "label": "Desktop Logo Height (px)",
                "type": "number",
                "default": 60,
                "min": 20,
                "max": 150
            },
            {
                "name": "menu_vertical_align",
                "label": "Vertical Alignment",
                "type": "choice",
                "choices": [
                    ["flex-start", "Top"],
                    ["center", "Middle"],
                    ["flex-end", "Bottom"]
                ],
                "default": "center",
                "help_text": "Vertically align the menu items."
            },
            {
                "name": "menu_horizontal_align",
                "label": "Horizontal Alignment",
                "type": "choice",
                "choices": [
                    ["left", "Left"],
                    ["center", "Center"],
                    ["right", "Right"],
                    ["justify", "Space Between"]
                ],
                "default": "center",
                "help_text": "Horizontally align the menu items."
            },
            {
                "name": "header_style_override",
                "label": "Header Style Override",
                "type": "choice",
                "choices": [
                    ["default", "Use Theme Default"],
                    ["glassmorphism", "Glassmorphism Light (Blur)"],
                    ["glassmorphism_dark", "Glassmorphism Dark (Industrial)"],
                    ["solid_white", "Solid White"],
                    ["solid_black", "Solid Black (Industrial)"],
                    ["transparent_light", "Transparent (Light Text)"],
                    ["transparent_dark", "Transparent (Dark Text)"],
                    ["minimal", "Minimal (Thin)"],
                    ["gradient_industrial", "Gradient (Industrial)"]
                ],
                "default": "default",
                "help_text": "Force a specific header style for this page."
            },
            {
                "name": "header_sticky_override",
                "label": "Sticky Header Override",
                "type": "choice",
                "choices": [
                    ["default", "Use Theme Default"],
                    ["sticky", "Enable (Sticky)"],
                    ["static", "Disable (Static)"]
                ],
                "default": "default",
                "help_text": "Force the header to be sticky or static on scroll."
            }
        ]
    },
    {
        "name": "mobile_settings",
        "label": "Mobile Menu Settings",
        "type": "group",
        "children": [
            {
                "name": "mobile_logo_height",
                "label": "Mobile Logo Height (px)",
                "type": "number",
                "default": 40,
                "min": 20,
                "max": 100
            },
            {
                "name": "mobile_menu_bg",
                "label": "Menu Overlay Background",
                "type": "color",
                "default": {
                    "color": "#080c10",
                    "opacity": 95
                }
            },
            {
                "name": "hamburger_color",
                "label": "Hamburger Color",
                "type": "color",
                "default": {
                    "color": "#f1f5f9"
                }
            },
            {
                "name": "mobile_menu_alignment",
                "label": "Mobile Menu Alignment",
                "type": "choice",
                "choices": [
                    ["left", "Left"],
                    ["center", "Center"]
                ],
                "default": "left"
            }
        ]
    },
    {
        "name": "cta_settings",
